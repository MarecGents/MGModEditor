<Page 
    x:Class="MGEditor.Views.Pages.Functions.EconomySystemPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:local="clr-namespace:MGEditor.Views.Pages.Functions"
    xmlns:system="clr-namespace:System;assembly=System.Runtime"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:controls="clr-namespace:MGEditor.Controls"
    Title="经济系统"
    d:DataContext="{d:DesignInstance local:EconomySystemPage,
                                IsDesignTimeCreatable=False}"
    d:DesignHeight="1200" 
    d:DesignWidth="700"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    mc:Ignorable="d" >
    <StackPanel>
        <controls:FrameGroup
            HeaderText="跳蚤市场">
            <StackPanel>
                <controls:ComboxFrame 
                    ButtonContent="跳蚤交易单倍数"
                    ItemsSource="{Binding ViewModel.ConfigItemList.SellNumber}"
                    SelectedValue="{Binding ViewModel.ConfigJson.Globals.SellNumber}"/>
                <controls:CheckButtonFrame
                    ButtonContent="跳蚤出售100%"
                    IsChecked="{Binding ViewModel.ConfigJson.Config.Sell100}"/>
                <controls:CheckButtonFrame
                    ButtonContent="跳蚤极速出售"
                    IsChecked="{Binding ViewModel.ConfigJson.Config.SellFast}"/>
                <controls:CheckButtonFrame
                    ButtonContent="跳蚤购买优化"
                    IsChecked="{Binding ViewModel.ConfigJson.Config.SellOptimize}"/>
                <controls:CheckButtonFrame
                    ButtonContent="跳蚤物品全新"
                    IsChecked="{Binding ViewModel.ConfigJson.Config.SellNew}"/>
                <controls:CheckButtonFrame
                    ButtonContent="禁用跳蚤黑名单"
                    IsChecked="{Binding ViewModel.ConfigJson.Config.NoBlackList}"/>
                <controls:CheckButtonFrame
                    ButtonContent="跳蚤开放等级"
                    IsChecked="{Binding ViewModel.ConfigJson.Globals.FleaMarketOpenLevel}"/>
                <controls:CheckButtonFrame
                    ButtonContent="极低税率"
                    IsChecked="{Binding ViewModel.ConfigJson.Globals.LowTaxRate}"/>
            </StackPanel>
        </controls:FrameGroup>
        
        <controls:FrameGroup
            HeaderText="商人交易">
            <StackPanel>
                <controls:ComboxFrame 
                    ButtonContent="商人供货时间"
                    ItemsSource="{Binding ViewModel.ConfigItemList.UpdateTime}"
                    SelectedValue="{Binding ViewModel.UpdateTimeValue}"/>
                <controls:ComboxFrame 
                    ButtonContent="回保速度"
                    ItemsSource="{Binding ViewModel.ConfigItemList.InsuranceTime}"
                    SelectedValue="{Binding ViewModel.InsuranceTimeValue}"/>
                <controls:ComboxFrame 
                    ButtonContent="投保费用"
                    ItemsSource="{Binding ViewModel.ConfigItemList.InsuranceCost}"
                    SelectedValue="{Binding ViewModel.InsuranceCostValue}"/>
                <controls:ComboxFrame 
                    ButtonContent="回保概率"
                    ItemsSource="{Binding ViewModel.ConfigItemList.ReturnChance}"
                    SelectedValue="{Binding ViewModel.ReturnChanceValue}"/>

                <controls:CheckButtonFrame
                    ButtonContent="购买物品带钩"
                    IsChecked="{Binding ViewModel.ConfigJson.Config.BuyFoundInRaid}"/>
            </StackPanel>
        </controls:FrameGroup>
        
    </StackPanel>
</Page>
