<Page 
    x:Class="MGEditor.Views.Pages.Functions.RaidSystemPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:local="clr-namespace:MGEditor.Views.Pages.Functions"
    xmlns:system="clr-namespace:System;assembly=System.Runtime"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:controls="clr-namespace:MGEditor.Controls"
    Title="战局系统"
    d:DataContext="{d:DesignInstance local:RaidSystemPage,
                                IsDesignTimeCreatable=False}"
    d:DesignHeight="1200" 
    d:DesignWidth="700"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    mc:Ignorable="d" >

    <StackPanel>
        
        <controls:FrameGroup
            HeaderText="AI设置">
            <StackPanel>
                <controls:ComboxFrame 
                    ButtonContent="AI血量"
                    ItemsSource="{Binding ViewModel.ConfigItemList.AIHealth}"
                    SelectedValue="{Binding ViewModel.ConfigJson.Bot.AIHealth}"/>
                <controls:ComboxFrame 
                    ButtonContent="AI刷新数量"
                    ItemsSource="{Binding ViewModel.ConfigItemList.AISpawnNumber}"
                    SelectedValue="{Binding ViewModel.ConfigJson.Config.AISpawnNumber}"/>
                <controls:ComboxFrame 
                    ButtonContent="USEC比例"
                    ItemsSource="{Binding ViewModel.ConfigItemList.USECRate}"
                    SelectedValue="{Binding ViewModel.UsecRateValue}"/>
            </StackPanel>
        </controls:FrameGroup>
        
        <controls:FrameGroup
            HeaderText="战局默认选项">
            <StackPanel>
                <controls:CheckButtonFrame
                    ButtonContent="默认选项自定义"
                    IsChecked="{Binding ViewModel.ConfigJson.Config.RaidDefault.enable}"/>
                <controls:ComboxFrame 
                    ButtonContent="AI数量"
                    ItemsSource="{Binding ViewModel.ConfigItemList.aiAmount}"
                    SelectedValue="{Binding ViewModel.ConfigJson.Config.RaidDefault.aiAmount}"
                    IsEnabled="{Binding ViewModel.ConfigJson.Config.RaidDefault.enable}"/>
                <controls:ComboxFrame 
                    ButtonContent="AI难度"
                    ItemsSource="{Binding ViewModel.ConfigItemList.aiDifficulty}"
                    SelectedValue="{Binding ViewModel.ConfigJson.Config.RaidDefault.aiDifficulty}"
                    IsEnabled="{Binding ViewModel.ConfigJson.Config.RaidDefault.enable}"/>
                <controls:CheckButtonFrame
                    ButtonContent="开启BOSS"
                    IsChecked="{Binding ViewModel.ConfigJson.Config.RaidDefault.bossEnabled}"
                    IsEnabled="{Binding ViewModel.ConfigJson.Config.RaidDefault.enable}"/>
                <controls:CheckButtonFrame
                    ButtonContent="Scav内战"
                    IsChecked="{Binding ViewModel.ConfigJson.Config.RaidDefault.scavWars}"
                    IsEnabled="{Binding ViewModel.ConfigJson.Config.RaidDefault.enable}"/>
                <controls:CheckButtonFrame
                    ButtonContent="标记诅咒"
                    IsChecked="{Binding ViewModel.ConfigJson.Config.RaidDefault.taggedAndCursed}"
                    IsEnabled="{Binding ViewModel.ConfigJson.Config.RaidDefault.enable}"/>
            </StackPanel>
        </controls:FrameGroup>

        <controls:FrameGroup
            HeaderText="战局设置">
            <StackPanel>
                <controls:ComboxFrame
                    ButtonContent="战局时长"
                    ItemsSource="{Binding ViewModel.ConfigItemList.RaidTime}"
                    SelectedValue="{Binding ViewModel.RaidTimeValue}"/>
                <controls:ComboxFrame
                    ButtonContent="BOSS刷新率"
                    ItemsSource="{Binding ViewModel.ConfigItemList.BOSSSpwanChance}"
                    SelectedValue="{Binding ViewModel.BossSpwanChanceValue}"/>
                <controls:ComboxFrame
                    ButtonContent="空投种类"
                    ItemsSource="{Binding ViewModel.ConfigItemList.AirdropType}"
                    SelectedValue="{Binding ViewModel.ConfigJson.Config.AirdropType}"/>
                <controls:CheckButtonFrame
                    ButtonContent="100%可拉闸"
                    IsChecked="{Binding ViewModel.ConfigJson.Locations.Pass100}"/>
                <controls:CheckButtonFrame
                    ButtonContent="100%可撤离"
                    IsChecked="{Binding ViewModel.ConfigJson.Locations.Escape100}"/>
                <controls:CheckButtonFrame
                    ButtonContent="撤离时间无限制"
                    IsChecked="{Binding ViewModel.ConfigJson.Globals.EscapeNoTimeLimit}"/>
                <controls:CheckButtonFrame
                    ButtonContent="Scav战局优化"
                    IsChecked="{Binding ViewModel.ConfigJson.Globals.ScavOptimize}"/>
            </StackPanel>
        </controls:FrameGroup>
        
        <controls:FrameGroup
            HeaderText="天气设置">
            <StackPanel>
                <controls:ComboxFrame
                    ButtonContent="全局天气设置"
                    ItemsSource="{Binding ViewModel.ConfigItemList.WeatherMode}"
                    SelectedValue="{Binding ViewModel.WeatherMode}"/>
                <controls:ComboxFrame
                    ButtonContent="云量修改"
                    ItemsSource="{Binding ViewModel.ConfigItemList.CloudMode}"
                    SelectedValue="{Binding ViewModel.CloudsMode}"
                    IsEnabled="{Binding ViewModel.WeatherSettingEnable}"/>
                <controls:ComboxFrame
                    ButtonContent="风量修改"
                    ItemsSource="{Binding ViewModel.ConfigItemList.WindMode}"
                    SelectedValue="{Binding ViewModel.WindMode}"
                    IsEnabled="{Binding ViewModel.WeatherSettingEnable}"/>
                <controls:ComboxFrame
                    ButtonContent="雨量修改"
                    ItemsSource="{Binding ViewModel.ConfigItemList.RainMode}"
                    SelectedValue="{Binding ViewModel.RainMode}"
                    IsEnabled="{Binding ViewModel.WeatherSettingEnable}"/>
                <controls:ComboxFrame
                    ButtonContent="雾量修改"
                    ItemsSource="{Binding ViewModel.ConfigItemList.FogMode}"
                    SelectedValue="{Binding ViewModel.FogMode}"
                    IsEnabled="{Binding ViewModel.WeatherSettingEnable}"/>
            </StackPanel>
        </controls:FrameGroup>

        <controls:FrameGroup
            HeaderText="资源设置">
            <StackPanel>
                <controls:ComboxFrame
                    ButtonContent="全局物资倍率"
                    ItemsSource="{Binding ViewModel.ConfigItemList.LootMultiple}"
                    SelectedValue="{Binding ViewModel.ConfigJson.Globals.LootMultiplier.Global}"/>
                <controls:ComboxFrame
                    ButtonContent="容器物资倍率"
                    ItemsSource="{Binding ViewModel.ConfigItemList.LootMultiple}"
                    SelectedValue="{Binding ViewModel.ConfigJson.Config.LootMultiple.Container}"/>
                <controls:ComboxFrame
                    ButtonContent="地面物资倍率"
                    ItemsSource="{Binding ViewModel.ConfigItemList.LootMultiple}"
                    SelectedValue="{Binding ViewModel.ConfigJson.Config.LootMultiple.Ground}"/>
                <controls:ComboxFrame
                    ButtonContent="贵重物品物资倍率"
                    ItemsSource="{Binding ViewModel.ConfigItemList.LootMultiple}"
                    SelectedValue="{Binding ViewModel.ConfigJson.Globals.LootMultiplier.Value}"/>
                <controls:CheckButtonFrame
                    ButtonContent="关闭容器随机生成"
                    IsChecked="{Binding ViewModel.ConfigJson.Config.RandomContainer}"/>
            </StackPanel>
        </controls:FrameGroup>

        <controls:FrameGroup
            HeaderText="地图回保">
            <StackPanel>
                
                <controls:CheckButtonFrame
                    ButtonContent="海关"
                    IsChecked="{Binding ViewModel.IsBigmapEnable}"/>
                
                <controls:CheckButtonFrame
                    ButtonContent="工厂"
                    IsChecked="{Binding ViewModel.IsFactoryEnable}"/>
                
                <controls:CheckButtonFrame
                    ButtonContent="立交桥"
                    IsChecked="{Binding ViewModel.IsInterchangeEnable}"/>
                
                <controls:CheckButtonFrame
                    ButtonContent="实验室"
                    IsChecked="{Binding ViewModel.IsLaboratoryEnable}"/>
                
                <controls:CheckButtonFrame
                    ButtonContent="灯塔"
                    IsChecked="{Binding ViewModel.IsLighthouseEnable}"/>
                
                <controls:CheckButtonFrame
                    ButtonContent="储备站"
                    IsChecked="{Binding ViewModel.IsRezervBaseEnable}"/>
                
                <controls:CheckButtonFrame
                    ButtonContent="中心区"
                    IsChecked="{Binding ViewModel.IsSandboxEnable}"/>
                
                <controls:CheckButtonFrame
                    ButtonContent="海岸线"
                    IsChecked="{Binding ViewModel.IsShorelineEnable}"/>

                <controls:CheckButtonFrame
                    ButtonContent="街区"
                    IsChecked="{Binding ViewModel.IsTarkovStreetsEnable}"/>
                
                <controls:CheckButtonFrame
                    ButtonContent="森林"
                    IsChecked="{Binding ViewModel.IsWoodsEnable}"/>

            </StackPanel>
        </controls:FrameGroup>
    </StackPanel>
</Page>
