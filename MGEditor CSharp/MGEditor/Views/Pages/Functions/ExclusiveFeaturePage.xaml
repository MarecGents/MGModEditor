<Page 
    x:Class="MGEditor.Views.Pages.Functions.ExclusiveFeaturePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
    xmlns:local="clr-namespace:MGEditor.Views.Pages.Functions"
    xmlns:system="clr-namespace:System;assembly=System.Runtime"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:controls="clr-namespace:MGEditor.Controls"
    Title="特色功能"
    d:DataContext="{d:DesignInstance local:ExclusiveFeaturePage,
                                IsDesignTimeCreatable=False}"
    d:DesignHeight="1200" 
    d:DesignWidth="700"
    ui:Design.Background="{DynamicResource ApplicationBackgroundBrush}"
    ui:Design.Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    Foreground="{DynamicResource TextFillColorPrimaryBrush}"
    mc:Ignorable="d" >

    <StackPanel>
        
        <controls:FrameGroup
            HeaderText="独立功能">
            <StackPanel>
                <controls:CheckButtonFrame
                    ButtonContent="独立商人"
                    IsChecked="{Binding ViewModel.ConfigJson.MGCustom.CustomTrader}"/>
                <controls:CheckButtonFrame
                    ButtonContent="独立物品"
                    IsChecked="{Binding ViewModel.ConfigJson.MGCustom.CustomItem}"/>
                <controls:CheckButtonFrame
                    ButtonContent="独立预设"
                    IsChecked="{Binding ViewModel.ConfigJson.MGCustom.CustomAssort}"/>
                <controls:CheckButtonFrame
                    ButtonContent="独立存档"
                    IsChecked="{Binding ViewModel.ConfigJson.MGCustom.CustomProfile}"/>
            </StackPanel>
        </controls:FrameGroup>
        
        <controls:FrameGroup
            HeaderText="其他功能">
            <StackPanel>
                <controls:CheckButtonFrame
                    ButtonContent="子弹数据"
                    IsChecked="{Binding ViewModel.ConfigJson.Templates.AmmoInfo}"/>
                <controls:CheckButtonFrame
                    ButtonContent="钥匙分类"
                    IsChecked="{Binding ViewModel.ConfigJson.MGCustom.KeyClassfy}"/>
                <controls:CheckButtonFrame
                    ButtonContent="实时跳蚤"
                    IsChecked="{Binding ViewModel.ConfigJson.MGCustom.SyncFlea}"/>
            </StackPanel>
        </controls:FrameGroup>
        
    </StackPanel>
</Page>
