<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:controls="clr-namespace:MGEditor.Controls">

    <Style TargetType="{x:Type controls:ContainerFrameGroup}">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ContainerFrameGroup}">
                    <controls:FrameGroup
                            HeaderText="{Binding HeaderText, RelativeSource={RelativeSource AncestorType={x:Type controls:ContainerFrameGroup}}}">
                        <StackPanel>
                            <controls:CheckButtonFrame
                                ButtonContent="开启扩容"
                                IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType={x:Type controls:ContainerFrameGroup}}}"/>      
                            <controls:ComboxFrame
                                ButtonContent="扩容宽度"
                                IsEnabled="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType={x:Type controls:ContainerFrameGroup}}}"
                                ItemsSource="{Binding ExpandWidthList, RelativeSource={RelativeSource AncestorType={x:Type controls:ContainerFrameGroup}}}"
                                SelectedValue="{Binding ExpandWidth, RelativeSource={RelativeSource AncestorType={x:Type controls:ContainerFrameGroup}}}"/>
                            <controls:ComboxFrame
                                ButtonContent="扩容高度"
                                IsEnabled="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType={x:Type controls:ContainerFrameGroup}}}"
                                ItemsSource="{Binding ExpandHeightList, RelativeSource={RelativeSource AncestorType={x:Type controls:ContainerFrameGroup}}}"
                                SelectedValue="{Binding ExpandHeight, RelativeSource={RelativeSource AncestorType={x:Type controls:ContainerFrameGroup}}}"/>
                            <controls:CheckButtonFrame
                                ButtonContent="兼容物品"
                                IsChecked="{Binding IsFilter, RelativeSource={RelativeSource AncestorType={x:Type controls:ContainerFrameGroup}}}"/>
                            <controls:CheckButtonFrame
                                ButtonContent="无负重"
                                IsChecked="{Binding IsNoWeight, RelativeSource={RelativeSource AncestorType={x:Type controls:ContainerFrameGroup}}}"/>
                        </StackPanel>
                    </controls:FrameGroup>
                </ControlTemplate>
            </Setter.Value>
        </Setter>

    </Style>


</ResourceDictionary>