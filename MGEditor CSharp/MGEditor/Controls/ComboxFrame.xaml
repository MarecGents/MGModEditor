<ResourceDictionary 
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"           
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"        
    xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
    xmlns:controls="clr-namespace:MGEditor.Controls">

    <Style TargetType="{x:Type controls:ComboxFrame}">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="SnapsToDevicePixels" Value="True" />
        <Setter Property="OverridesDefaultStyle" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:ComboxFrame}">
                    <Grid>
                        <Border
                            Padding="5"
                            Background="{ui:ThemeResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{ui:ThemeResource CardStrokeColorDefaultBrush}"
                            BorderThickness="1,1,1,1"
                            CornerRadius="5,5,5,5">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition MinWidth="200" Width="*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <ui:Button
                                    Grid.Column="0"
                                    Content="{TemplateBinding ButtonContent}"
                                    HorizontalAlignment="Left"
                                    VerticalAlignment="Center"
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    Width="180"
                                    Margin="20,0,0,0"/>
                                <ComboBox
                                    Grid.Column="1"
                                    ItemsSource="{Binding ItemsSource, RelativeSource={RelativeSource AncestorType={x:Type controls:ComboxFrame}}}"
                                    SelectedValue="{Binding SelectedValue, RelativeSource={RelativeSource AncestorType={x:Type controls:ComboxFrame}}}"
                                    DisplayMemberPath="Value"
                                    SelectedValuePath="Key"
                                    Margin="0,0,20,0"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    MinWidth="150"
                                    />
                            </Grid>
                        </Border>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
            
    </Style>
    
</ResourceDictionary>